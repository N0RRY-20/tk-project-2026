{
  "name": "tkproject",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/fix-kysely.js && next build",
    "build-config": "node scripts/fix-kysely.js && set NODE_OPTIONS=--max-old-space-size=4096 && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --env-file .env --import tsx scripts/seed-user.ts",
    "db:seed-test": "node --env-file .env --import tsx scripts/test.ts",
    "auth:generate": "npx auth@latest generate --config ./src/lib/better-auth/auth.ts",
    "postinstall": "node scripts/fix-kysely.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@elevenlabs/elevenlabs-js": "^2.51.0",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-table": "^8.21.3",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13",
    "kysely": "0.28.17",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.8.0",
    "shadcn": "^4.10.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "kysely": "0.28.17"
  }
